@page "/transactions"

@inject IGetTransactionsBySearchUseCase actionGetTransactionsBySearch
@inject INavigationHistoryService navigation
@inject NotificationHelper messageThis

<section class="justify-content-center" id="idTransactionListing">
    <!-- filter controls -->
    <div class="d-flex flex-row gap-3 p-2">
        <!-- Date Range -->
        <label>Dates</label>
        <InputDateRange InputId="idFilterDate"
                        BeginDate="filterDate.Begin"
                        EndDate="filterDate.End"
                        BeginDateChanged="OnBeginDateChanged"
                        EndDateChanged="OnEndDateChanged" />

        <!-- Text Search -->
        <label>Search</label>
        <InputText id="idFilterText"
                   class="form-control"
                   @bind-Value="filterText"
                   @onchange="OnSearchTextChanged" />

        <ActionIconButton ButtonId="btnSearch"
                          ButtonType="button"
                          IconOption="IconOpt.LightBulb"
                          OnClickHandler="ProcessFilter" />
        <ActionIconButton ButtonId="btnClearFilters"
                          ButtonType="reset"
                          IconOption="IconOpt.Refresh"
                          OnClickHandler="ClearFilters" />

    </div>

    <br />
    <ul class="list-group">
        <li class="list-group-item">
            <div class="row header">

                <div class="col-1">
                    <!-- Action Buttons -->
                </div>

                <div class="col-1">
                    <h5>Date</h5>
                </div>

                <div class="col-2">
                    <h5>Debit</h5>
                </div>

                <div class="col-2">
                    <h5>Credit</h5>
                </div>

                <div class="col-5">
                    <h5>Description</h5>
                </div>

                <div class="col-1">
                    <h5>Amount</h5>
                </div>
            </div>
        </li>

        @{
            int counter = 0;
            foreach (var money in MoneyList.OrderBy(o => o.TransactionDate).ThenBy(o => o.Description))
            {
                counter++;
                <li class="list-group-item @(counter % 2 == 0 ? "altrow" : "")">
                    <TransactionItem Money="money" />
                </li>
            }
        }
    </ul>
    <br />
</section>



@code {
    List<IMoneyTransaction> MoneyList { get; set; } = new List<IMoneyTransaction>();

    private DateRange filterDate = new DLPMoneyTracker.Core.DateRange();
    private string filterText = string.Empty;

    protected override void OnInitialized()
    {
        filterDate = new DateRange(DateTime.MinValue, DateTime.MaxValue);
        this.ProcessFilter();
    }

    private void OnBeginDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value.ToString(), out DateTime begin))
        {
            filterDate.Begin = begin;
        }
    }

    private void OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value.ToString(), out DateTime end))
        {
            filterDate.End = end;
        }
    }

    private void OnSearchTextChanged(ChangeEventArgs e)
    {
        filterText = e.Value.ToString();
    }

    private void ProcessFilter()
    {
        MoneyList.Clear();

        var listData = actionGetTransactionsBySearch.Execute(filterDate, filterText, null);
        if (listData?.Any() != true) return;

        MoneyList.AddRange(listData);
    }

    private void ClearFilters()
    {
        filterDate.Begin = DateTime.MinValue;
        filterDate.End = DateTime.MaxValue;
        filterText = string.Empty;
    }
}
