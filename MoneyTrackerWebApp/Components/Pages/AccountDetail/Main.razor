@page "/detail/{AccountId:guid}"

@inherits DetailBase

<section id="account_detail_@AccountId">
    <div class="row">
        <div class="col-7">
            <h1>@account.Description</h1>
            <h3>@string.Format("{0:c}", currBalance)</h3>
        </div>

        <div class="col-5">
            <Top5ExpenseChart 
                AccountId="AccountId" 
                Dates="filterDate" />
        </div>
    </div>


    @* <div class="d-flex flex-row gap-3 p-2">
        <label>Date Range</label>
        <InputDateRange InputId="idFilterDate"
        BeginDate="filterDate.Begin"
        EndDate="filterDate.End"
        BeginDateChanged="OnFilterDateBeginChanged"
        EndDateChanged="OnFilterDateEndChanged" />

    </div> *@
    <div class="row">
        <div class="col-12">
            <TransactionListing 
            Account="account"
            BegDate="filterDate.Begin"
            EndDate="filterDate.End" />
        </div>
    </div>

</section>


